# .env.docker.example
# Template des variables d'environnement pour docker-compose
# À copier vers: .env.docker et adapter les valeurs
# Usage: docker compose --env-file .env.docker up -d

# ============================================================
# 🗄️  DATABASE - PostgreSQL Configuration
# ============================================================
# Utilisateur administrateur PostgreSQL
DB_USER=postgres

# Mot de passe administrateur (générer un secret forte en prod)
DB_PASSWORD=postgres

# Nom de la base de données
DB_NAME=emploi_plus_db_cg

# Port PostgreSQL (défaut 5432)
DB_PORT=5432

# ============================================================
# 🔙 BACKEND - Configuration Node.js Express
# ============================================================

# Environnement d'exécution
NODE_ENV=development
# Pour production: NODE_ENV=production

# Port d'écoute du serveur (intérieur du conteneur)
BACKEND_PORT=5000

# ============================================================
# 🔐 SÉCURITÉ - Clés et Tokens
# ============================================================

# JWT Secret - Clé pour signer les tokens JWT
# 🚨 IMPORTANT: Générer une clé forte en production!
# Commande: openssl rand -hex 32
JWT_SECRET=your_jwt_secret_key_min_32_characters_change_this_in_production

# CORS Origins - Domaines autorisés à appeler l'API
# Développement: http://localhost
# Production: https://votre-domaine.com
CORS_ORIGIN=http://localhost

# ============================================================
# 🤖 APIS EXTERNES
# ============================================================

# Google Gemini API Key - Pour l'IA Candidatures Intelligentes
GEMINI_API_KEY=AIzaSyDSAj76TtI_KjzrEZi-hSMji-WqH2GOXnQ

# Sitemap Token - Token de sécurité pour refresh du sitemap
# 🚨 À changer en production!
# Commande: openssl rand -hex 32
SITEMAP_TOKEN=your_sitemap_token_change_this_in_production

# ============================================================
# 📧 EMAIL - Configuration Nodemailer (Optionnel)
# ============================================================

# Host du serveur SMTP
# MAIL_HOST=smtp.gmail.com
# MAIL_HOST=smtp.SendGrid.net

# Port SMTP (587 pour TLS, 465 pour SSL)
# MAIL_PORT=587

# Email de connexion
# MAIL_USER=your-email@gmail.com

# Mot de passe ou token
# MAIL_PASSWORD=your-app-password

# Email d'envoi (from)
# MAIL_FROM=noreply@emploiplus-group.com

# ============================================================
# 🌐 FRONTEND - Configuration Vite React
# ============================================================

# URL de l'API côté client (navigateur)
# Développement: http://localhost/api
# Production: https://votre-domaine.com/api
VITE_API_URL=http://localhost/api

# ============================================================
# 🐳 DOCKER - Configuration Globale
# ============================================================

# Timezone des conteneurs
TZ=UTC

# ============================================================
# 📝 INDEX EXAMPLE DE TYPE DE SECRETS À GÉNÉRER
# ============================================================
# Pour générer des secrets forts:
#
# $ openssl rand -hex 32
# a7f3e9c1b5d2f8a4e7f6c1d3b5a8e2f9c4d7e1a9f3b5c8d1e2
#
# Copiez le résultat dans les champs JWT_SECRET et SITEMAP_TOKEN
