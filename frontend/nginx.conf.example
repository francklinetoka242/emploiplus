# nginx.conf - SPA Routing Configuration
# Use this configuration if your server uses Nginx instead of Apache
# This should be in the server {} block of your nginx.conf

server {
    listen 80;
    listen 443 ssl http2;
    server_name emploiplus-group.com www.emploiplus-group.com;

    # SSL Certificate (configure if using HTTPS)
    # ssl_certificate /path/to/certificate.crt;
    # ssl_certificate_key /path/to/private.key;

    # Add your project root path here (adjust based on deployment)
    root /var/www/emploi-connect;
    index index.html index.htm;

    # ===== MOST IMPORTANT: SPA ROUTING =====
    # Redirect all requests that are NOT files/directories to index.html
    location / {
        try_files $uri $uri/ /index.html;
    }

    # ===== API PROXY =====
    # Forward API requests to your backend server
    location /api/ {
        proxy_pass http://127.0.0.1:5000;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_cache_bypass $http_upgrade;
    }

    # ===== UPLOADS PROXY =====
    # Forward file uploads to backend
    location /uploads/ {
        proxy_pass http://127.0.0.1:5000;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # ===== STATIC ASSETS =====
    # Cache static files with hash in filename
    location ~* \.(js|css|png|jpg|jpeg|gif|ico|svg|woff|woff2|ttf|otf)$ {
        expires 1y;
        add_header Cache-Control "public, immutable";
    }

    # Don't cache index.html
    location = /index.html {
        expires 0;
        add_header Cache-Control "public, must-revalidate, max-age=0";
    }

    # ===== SECURITY HEADERS =====
    add_header X-Content-Type-Options "nosniff" always;
    add_header X-XSS-Protection "1; mode=block" always;
    add_header X-Frame-Options "SAMEORIGIN" always;
    add_header Referrer-Policy "strict-origin-when-cross-origin" always;

    # ===== COMPRESSION =====
    gzip on;
    gzip_vary on;
    gzip_proxied any;
    gzip_comp_level 6;
    gzip_types text/plain text/css text/xml text/javascript application/json application/javascript application/xml+rss;

    # Disable directory listing
    autoindex off;

    # Hide .htaccess and other sensitive files
    location ~ /\. {
        deny all;
    }
}
